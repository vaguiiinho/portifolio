datasource db {
  provider = "postgresql"
}


generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

enum UserRole {
  visitante
  administrador
}


model Project {
  id                 String   @id @default(cuid())
  title              String   @db.VarChar(255)
  description        String
  techStack          String[]
  githubUrl          String?  @db.VarChar(512)
  liveUrl            String?  @db.VarChar(512)
  videoUrl           String?  @db.Text
  problemTitle       String?  @db.VarChar(255)
  problemDescription String?
  solutionTitle      String?  @db.VarChar(255)
  solutionDescription String?
  resultTitle        String?  @db.VarChar(255)
  resultDescription  String?
  featured           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("projects")
}

model Contact {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
}

model Stats {
  id            String   @id @default(cuid())
  projectsCount Int      @default(0)
  visitors      Int      @default(0)
  events        Json     @default("{}")
  updatedAt     DateTime @updatedAt

  @@map("stats")
}

model Config {
  id                String   @id @default(cuid())
  siteName          String   @db.VarChar(255)
  description       String
  aboutBio          Json     @default("[]")
  servicesContent    Json     @default("{}")
  testimonialsContent Json     @default("{}")
  updatedAt         DateTime @updatedAt

  @@map("config")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(administrador)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
