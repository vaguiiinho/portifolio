DATABASE_URL="postgresql://root:password@localhost:5432/portifolio_db"
PORT=3001
# Used when running the frontend development server directly. The production
# compose file overrides this from the root .env file.
CORS_ORIGIN=http://localhost:3000
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN_SECONDS=86400
# In production AUTH_COOKIE_SECURE must be true. Set SAME_SITE=none only for HTTPS cross-site use.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# Leave empty for the current host; use a shared parent domain only when required.
AUTH_COOKIE_DOMAIN=
TESTCONTAINERS_HOST_OVERRIDE=host.docker.internal

# Required once to create the first administrator with npm run db:seed.
ADMIN_EMAIL=
ADMIN_PASSWORD=
